rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Admin Check
    // Admin is either the hardcoded bootstrap user or someone with 'rol' == 'admin'
    function isBootstrapAdmin() {
      return request.auth.token.email_verified == true && request.auth.token.email == 'yesicalp@gmail.com';
    }
    
    function isAdmin() {
      return isSignedIn() && isBootstrapAdmin();
    }

    // User Validation
    function isValidUser(data) {
      return data.keys().hasAll(['nombre', 'apellido', 'rol'])
        && data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 100
        && data.apellido is string && data.apellido.size() > 0 && data.apellido.size() <= 100
        && data.get('instagram_handle', '') is string && data.get('instagram_handle', '').size() <= 100
        && data.rol in ['staff', 'admin'];
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /publicaciones/{publicacionId} {
      allow read, create, update: if true;
      allow delete: if isAdmin() || (isSignedIn() && existing().estudiante_id == request.auth.uid && existing().estado == 'borrador');
      
      match /reacciones/{reaccionId} {
        allow read, create: if true;
      }
    }
  }
}

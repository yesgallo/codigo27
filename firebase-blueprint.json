{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "User profile extending Auth identity",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "apellido": { "type": "string" },
        "instagram_handle": { "type": "string" },
        "rol": { "type": "string", "enum": ["staff", "admin"] }
      },
      "required": ["nombre", "apellido", "rol"]
    },
    "publicacion": {
      "title": "Publication",
      "description": "A journalistic publication by a student",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "cuerpo": { "type": "string" },
        "formato": { "type": "string", "enum": ["texto", "video", "audio"] },
        "media_url": { "type": "string" },
        "imagen_portada": { "type": "string" },
        "estado": { "type": "string", "enum": ["borrador", "publicado", "observado"] },
        "comentario_docente": { "type": "string" },
        "estudiante_id": { "type": "string" },
        "fecha_publicacion": { "type": "number" },
        "created_at": { "type": "number" },
        "estadisticas": {
          "type": "object",
          "properties": {
            "reacciones_interesa": { "type": "number" },
            "reacciones_enoja": { "type": "number" },
            "reacciones_alegra": { "type": "number" },
            "reacciones_entristece": { "type": "number" },
            "reacciones_piensa": { "type": "number" }
          }
        }
      },
      "required": ["titulo", "formato", "estado", "estudiante_id", "created_at"]
    },
    "reaccion": {
      "title": "Reaction",
      "description": "Anonymous reaction to a publication",
      "type": "object",
      "properties": {
        "tipo": { "type": "string", "enum": ["interesa", "enoja", "alegra", "entristece", "piensa"] },
        "created_at": { "type": "number" }
      },
      "required": ["tipo", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/user" },
      "description": "User profiles (Staff and Admin)"
    },
    "/publicaciones/{publicacionId}": {
      "schema": { "$ref": "#/entities/publicacion" },
      "description": "Journalistic productions"
    },
    "/publicaciones/{publicacionId}/reacciones/{reaccionId}": {
      "schema": { "$ref": "#/entities/reaccion" },
      "description": "Anonymous reactions"
    }
  }
}
